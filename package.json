{
  "name": "zhaocai-ip-center",
  "version": "2.0.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "bootstrap:gateway-alias-routing": "node --experimental-strip-types scripts/bootstrap-gateway-alias-routing.ts",
    "bootstrap:gateway-alias-routing:write": "node --experimental-strip-types scripts/bootstrap-gateway-alias-routing.ts --write",
    "test:gateway-cutover": "node --experimental-strip-types tests/model-routing-env.test.mjs",
    "test:zhaocai-center:evolution": "node --experimental-strip-types tests/evolution-decision-logic.test.mjs",
    "test:zhaocai-center:demo": "node --experimental-strip-types tests/demo-playbook-service.test.mjs",
    "lint": "next lint",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:seed": "docker exec -i content-ip-workbench-postgres psql -U postgres -d content_ip_workbench < prisma/seed.sql"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "fast-xml-parser": "^5.5.5",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prisma": "^6.0.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0"
  }
}
