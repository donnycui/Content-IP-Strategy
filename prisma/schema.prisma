generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum SourceType {
  RSS
  WEBSITE
  NEWSLETTER
  MANUAL_URL
  SOCIAL_LINK
  DISCLOSURE
  BLOG
}

enum SignalStatus {
  NEW
  REVIEWED
  CANDIDATE
  DEFERRED
  IGNORED
  ARCHIVED
}

enum ReviewStatus {
  PENDING
  KEPT
  REJECTED
  DEFERRED
}

enum ReasoningAcceptance {
  ACCEPTED
  PARTIAL
  REJECTED
}

enum ClusterStatus {
  ACTIVE
  MERGED
  ARCHIVED
}

enum ResearchCardStatus {
  DRAFT
  READY
  ARCHIVED
}

enum DraftPlatform {
  WECHAT_ARTICLE
  WECHAT_VIDEO
  SHORT_POST
}

enum DraftStatus {
  DRAFT
  READY
  PUBLISHED
  ARCHIVED
}

enum PriorityRecommendation {
  PRIORITIZE
  WATCH
  DEPRIORITIZE
}

enum ObservationCluster {
  ai_infrastructure_power
  platform_entry_shift
  strategic_supply_control
  compute_capex_cycle
  policy_capital_allocation
  risk_repricing_cycle
  profit_pool_shift
  distribution_model_break
  ai_revenue_rebuild
  org_efficiency_reorg
  individual_capability_shift
  sme_positioning_shift
}

enum TagType {
  TOPIC
  COMPANY
  PERSON
  COUNTRY
  INDUSTRY
  MOTHER_THEME
}

enum CreatorStage {
  EXPLORING
  EMERGING
  SCALING
  ESTABLISHED
}

enum DirectionPriority {
  PRIMARY
  SECONDARY
  WATCH
}

enum DirectionStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

enum TopicStatus {
  ACTIVE
  WATCHING
  ARCHIVED
}

enum TopicCandidateStatus {
  NEW
  KEPT
  DEFERRED
  REJECTED
}

enum TopicFormatRecommendation {
  SINGLE_POST
  RECURRING_TRACK
  SERIES_ENTRY
}

enum ProfileUpdateSuggestionType {
  POSITIONING
  PERSONA
  AUDIENCE
  CORE_THEME
  VOICE_STYLE
  GROWTH_GOAL
  CONTENT_BOUNDARY
  CURRENT_STAGE
  DIRECTION_WEIGHT
}

enum SuggestionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum ProfileExtractionSessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum ProfileExtractionSourceMode {
  CONVERSATIONAL
}

enum GatewayAuthType {
  NONE
  BEARER
  API_KEY
  PASSCODE
}

enum GatewayHealthStatus {
  UNKNOWN
  HEALTHY
  DEGRADED
  ERROR
}

enum ModelTier {
  FAST
  BALANCED
  DEEP
}

enum ModelCapabilityKey {
  signal_scoring
  ip_extraction_interview
  ip_strategy_report
  direction_generation
  topic_generation
  topic_candidate_generation
  profile_evolution
  draft_generation
}

enum CenterAgentKey {
  IP_EXTRACTION
  CREATOR_PROFILE
  TOPIC_DIRECTION
  STYLE_CONTENT
  DAILY_REVIEW
  EVOLUTION
}

enum AgentThreadStatus {
  IDLE
  ACTIVE
  PAUSED
  ARCHIVED
}

enum SharedMemoryCategory {
  PROFILE_SNAPSHOT
  PROFILE_EVOLUTION_NOTE
  STYLE_SNAPSHOT
  STYLE_EVOLUTION_NOTE
  KEY_CONCLUSION
  REVIEW_TREND
  LEARNING_INSIGHT
}

enum StyleSkillStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum ContentProjectStatus {
  DRAFT
  ACTIVE
  READY
  ARCHIVED
}

enum ContentAssetType {
  XHS_POST
  SHORT_VIDEO_SCRIPT
  WECHAT_ARTICLE
  LIVESTREAM_SCRIPT
}

enum ContentAssetStatus {
  DRAFT
  READY
  APPROVED
  ARCHIVED
}

enum PublishMode {
  EXPORT
  DIRECT
}

enum PublishStatus {
  DRAFT
  READY
  EXPORTED
  QUEUED
  PUBLISHED
  FAILED
}

enum EvolutionTargetType {
  PROFILE
  STYLE
  DIRECTION
  PLATFORM_STRATEGY
}

enum EvolutionDecisionStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model CreatorProfile {
  id                String                    @id @default(cuid())
  name              String
  positioning       String?
  persona           String?
  audience          String?
  coreThemes        String?
  voiceStyle        String?
  growthGoal        String?
  contentBoundaries String?
  currentStage      CreatorStage             @default(EXPLORING)
  isActive          Boolean                  @default(true)
  createdAt         DateTime                 @default(now())
  updatedAt         DateTime                 @updatedAt

  directions        Direction[]
  topics            Topic[]
  profileUpdates    ProfileUpdateSuggestion[]
  modelUsageLogs    ModelUsageLog[]
  centerWorkspaces  CenterWorkspace[]
  styleSkills       StyleSkill[]
  contentProjects   ContentProject[]

  @@index([isActive, updatedAt])
}

model Direction {
  id               String            @id @default(cuid())
  creatorProfileId String
  title            String
  whyNow           String?
  fitReason        String?
  priority         DirectionPriority @default(SECONDARY)
  status           DirectionStatus   @default(ACTIVE)
  timeHorizon      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  creatorProfile   CreatorProfile    @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  topics           Topic[]

  @@index([creatorProfileId, status, priority])
}

model Topic {
  id                          String                     @id @default(cuid())
  creatorProfileId            String
  directionId                 String?
  title                       String
  summary                     String?
  status                      TopicStatus                @default(ACTIVE)
  heatScore                   Float?
  signalCount                 Int                        @default(0)
  primaryObservationCluster   ObservationCluster?
  secondaryObservationCluster ObservationCluster?
  createdAt                   DateTime                   @default(now())
  updatedAt                   DateTime                   @updatedAt

  creatorProfile              CreatorProfile             @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)
  direction                   Direction?                 @relation(fields: [directionId], references: [id], onDelete: SetNull)
  candidates                  TopicCandidate[]

  @@index([creatorProfileId, status, updatedAt])
  @@index([directionId, heatScore])
}

model TopicCandidate {
  id                   String                    @id @default(cuid())
  topicId              String
  anchorSignalId       String?
  title                String
  whyNow               String?
  fitReason            String?
  formatRecommendation TopicFormatRecommendation @default(SINGLE_POST)
  priority             DirectionPriority         @default(SECONDARY)
  status               TopicCandidateStatus      @default(NEW)
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  topic                Topic                      @relation(fields: [topicId], references: [id], onDelete: Cascade)
  anchorSignal         Signal?                    @relation(fields: [anchorSignalId], references: [id], onDelete: SetNull)
  contentProjects      ContentProject[]

  @@index([topicId, status, updatedAt])
  @@index([anchorSignalId])
}

model ProfileUpdateSuggestion {
  id               String                      @id @default(cuid())
  creatorProfileId String
  type             ProfileUpdateSuggestionType
  beforeValue      String?
  suggestedValue   String
  reason           String
  confidence       Float?
  status           SuggestionStatus            @default(PENDING)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt

  creatorProfile   CreatorProfile              @relation(fields: [creatorProfileId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId, status, createdAt])
  @@index([type, status])
}

model ProfileExtractionSession {
  id              String                         @id @default(cuid())
  status          ProfileExtractionSessionStatus @default(ACTIVE)
  sourceMode      ProfileExtractionSourceMode    @default(CONVERSATIONAL)
  transcriptJson  Json
  draftProfileJson Json
  currentQuestion String?
  questionType    String?
  turnCount       Int                            @default(0)
  lastUserMessage String?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@index([status, updatedAt])
}

model CenterWorkspace {
  id                     String          @id @default(cuid())
  workspaceKey           String          @unique
  creatorProfileId       String?         @unique
  currentAgentKey        CenterAgentKey  @default(IP_EXTRACTION)
  recommendedActionLabel String?
  recommendedActionHref  String?
  lastStageReason        String?
  lastJudgedAt           DateTime?
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt

  creatorProfile         CreatorProfile? @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)
  agentThreads           AgentThread[]
  sharedMemoryRecords    SharedMemoryRecord[]
  styleSkill             StyleSkill?
  contentProjects        ContentProject[]
  platformStrategyMemos  PlatformStrategyMemo[]
  reviewSnapshots        ReviewSnapshot[]
  evolutionDecisions     EvolutionDecision[]

  @@index([currentAgentKey, updatedAt])
}

model PlatformStrategyMemo {
  id          String         @id @default(cuid())
  workspaceId String
  channelKey  String
  headline    String
  summary     String
  detail      String?
  sourceRef   String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  workspace   CenterWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, channelKey])
  @@index([workspaceId, updatedAt])
}

model AgentThread {
  id                    String            @id @default(cuid())
  workspaceId           String
  agentKey              CenterAgentKey
  status                AgentThreadStatus @default(IDLE)
  transcriptJson        Json              @default("[]")
  summaryJson           Json?
  latestSummary         String?
  nextRecommendedAction String?
  lastUserMessage       String?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  workspace             CenterWorkspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, agentKey])
  @@index([workspaceId, updatedAt])
  @@index([status, updatedAt])
}

model SharedMemoryRecord {
  id           String               @id @default(cuid())
  workspaceId  String
  agentKey     CenterAgentKey?
  category     SharedMemoryCategory
  title        String
  summary      String
  detail       String?
  sourceRef    String?
  payloadJson  Json?
  isActive     Boolean              @default(true)
  effectiveAt  DateTime             @default(now())
  supersededAt DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  workspace    CenterWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, category, isActive, effectiveAt])
  @@index([workspaceId, createdAt])
  @@index([agentKey, createdAt])
}

model StyleSkill {
  id             String           @id @default(cuid())
  workspaceId    String           @unique
  creatorProfileId String?
  status         StyleSkillStatus @default(DRAFT)
  title          String           @default("个人风格 Skill")
  summary        String
  rulesMarkdown  String
  version        Int              @default(1)
  revisionCount  Int              @default(0)
  sampleCount    Int              @default(0)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  workspace      CenterWorkspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creatorProfile CreatorProfile?  @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)
  samples        StyleSample[]
  revisions      StyleRevision[]
  contentProjects ContentProject[]

  @@index([creatorProfileId, updatedAt])
  @@index([status, updatedAt])
}

model StyleSample {
  id          String      @id @default(cuid())
  styleSkillId String
  title       String
  sourceLabel String?
  sampleText  String
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  styleSkill  StyleSkill  @relation(fields: [styleSkillId], references: [id], onDelete: Cascade)
  revisions   StyleRevision[]

  @@index([styleSkillId, createdAt])
}

model StyleRevision {
  id          String      @id @default(cuid())
  styleSkillId String
  sampleId    String?
  draftText   String
  revisedText String
  ruleDelta   String?
  createdAt   DateTime    @default(now())

  styleSkill  StyleSkill  @relation(fields: [styleSkillId], references: [id], onDelete: Cascade)
  sample      StyleSample? @relation(fields: [sampleId], references: [id], onDelete: SetNull)

  @@index([styleSkillId, createdAt])
  @@index([sampleId])
}

model ContentProject {
  id               String               @id @default(cuid())
  workspaceId      String
  creatorProfileId String?
  topicCandidateId String?
  styleSkillId     String?
  status           ContentProjectStatus @default(DRAFT)
  title            String
  summary          String?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  workspace        CenterWorkspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  creatorProfile   CreatorProfile?      @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)
  topicCandidate   TopicCandidate?      @relation(fields: [topicCandidateId], references: [id], onDelete: SetNull)
  styleSkill       StyleSkill?          @relation(fields: [styleSkillId], references: [id], onDelete: SetNull)
  assets           ContentAsset[]
  publishRecords   PublishRecord[]
  reviewSnapshots  ReviewSnapshot[]

  @@index([workspaceId, status, updatedAt])
  @@index([creatorProfileId, updatedAt])
  @@index([topicCandidateId])
}

model ContentAsset {
  id             String             @id @default(cuid())
  projectId      String
  assetType      ContentAssetType
  title          String?
  content        String
  targetPlatform String
  status         ContentAssetStatus @default(DRAFT)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  project        ContentProject     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  publishRecords PublishRecord[]
  reviewSnapshots ReviewSnapshot[]

  @@unique([projectId, assetType])
  @@index([targetPlatform, status, updatedAt])
}

model PublishRecord {
  id             String        @id @default(cuid())
  projectId      String
  assetId        String?
  channelKey     String
  mode           PublishMode   @default(EXPORT)
  status         PublishStatus @default(DRAFT)
  packageJson    Json?
  publishedAt    DateTime?
  failureReason  String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  project        ContentProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset          ContentAsset?  @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([projectId, createdAt])
  @@index([channelKey, status, createdAt])
  @@index([assetId])
}

model ReviewSnapshot {
  id             String        @id @default(cuid())
  workspaceId     String
  projectId       String
  assetId         String?
  channelKey      String
  views           Int?
  likes           Int?
  comments        Int?
  shares          Int?
  saves           Int?
  inquiries       Int?
  leads           Int?
  conversions     Int?
  reviewNote      String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  workspace       CenterWorkspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project         ContentProject  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  asset           ContentAsset?   @relation(fields: [assetId], references: [id], onDelete: SetNull)
  evolutionDecisions EvolutionDecision[]

  @@index([workspaceId, createdAt])
  @@index([projectId, createdAt])
  @@index([channelKey, createdAt])
  @@index([assetId])
}

model EvolutionDecision {
  id               String                  @id @default(cuid())
  workspaceId      String
  reviewSnapshotId String?
  targetType       EvolutionTargetType
  status           EvolutionDecisionStatus @default(PENDING)
  headline         String
  rationale        String
  suggestedAction  String
  actionPayloadJson Json?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  workspace        CenterWorkspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  reviewSnapshot   ReviewSnapshot?         @relation(fields: [reviewSnapshotId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, updatedAt])
  @@index([targetType, createdAt])
  @@index([reviewSnapshotId])
}

model GatewayConnection {
  id            String               @id @default(cuid())
  name          String
  baseUrl       String
  authType      GatewayAuthType      @default(NONE)
  authSecretRef String?
  isActive      Boolean              @default(true)
  healthStatus  GatewayHealthStatus  @default(UNKNOWN)
  lastSyncedAt  DateTime?
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  managedModels ManagedModel[]
  usageLogs     ModelUsageLog[]

  @@index([isActive, healthStatus])
  @@unique([name])
}

model ManagedModel {
  id                     String            @id @default(cuid())
  gatewayConnectionId    String
  providerKey            String
  modelKey               String
  displayName            String
  capabilityTags         Json?
  tier                   ModelTier        @default(BALANCED)
  enabled                Boolean          @default(true)
  visibleToUsers         Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  gatewayConnection      GatewayConnection @relation(fields: [gatewayConnectionId], references: [id], onDelete: Cascade)
  defaultCapabilityRoutes CapabilityRoute[] @relation("DefaultCapabilityRouteModel")
  fallbackCapabilityRoutes CapabilityRoute[] @relation("FallbackCapabilityRouteModel")
  usageLogs              ModelUsageLog[]

  @@unique([gatewayConnectionId, providerKey, modelKey])
  @@index([enabled, tier])
  @@index([gatewayConnectionId, visibleToUsers])
}

model CapabilityRoute {
  id                 String             @id @default(cuid())
  capabilityKey      ModelCapabilityKey
  defaultModelId     String
  fallbackModelId    String?
  allowFallback      Boolean            @default(false)
  allowUserOverride  Boolean            @default(false)
  notes              String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  defaultModel       ManagedModel       @relation("DefaultCapabilityRouteModel", fields: [defaultModelId], references: [id], onDelete: Cascade)
  fallbackModel      ManagedModel?      @relation("FallbackCapabilityRouteModel", fields: [fallbackModelId], references: [id], onDelete: SetNull)

  @@unique([capabilityKey])
  @@index([defaultModelId])
  @@index([fallbackModelId])
}

model PlanModelAccess {
  id                    String              @id @default(cuid())
  planKey               String
  capabilityKey         ModelCapabilityKey?
  allowedTier           ModelTier
  canSelectModel        Boolean             @default(false)
  canUsePremiumReasoning Boolean            @default(false)
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  @@index([planKey, capabilityKey])
  @@unique([planKey, capabilityKey, allowedTier])
}

model ModelUsageLog {
  id                   String              @id @default(cuid())
  creatorProfileId     String?
  gatewayConnectionId  String
  modelId              String
  capabilityKey        ModelCapabilityKey
  channel              String?
  latencyMs            Int?
  estimatedCost        Decimal?            @db.Decimal(10, 4)
  success              Boolean             @default(true)
  errorCode            String?
  createdAt            DateTime            @default(now())

  creatorProfile       CreatorProfile?     @relation(fields: [creatorProfileId], references: [id], onDelete: SetNull)
  gatewayConnection    GatewayConnection   @relation(fields: [gatewayConnectionId], references: [id], onDelete: Cascade)
  model                ManagedModel        @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([creatorProfileId, createdAt])
  @@index([gatewayConnectionId, createdAt])
  @@index([modelId, createdAt])
  @@index([capabilityKey, createdAt])
}

model Source {
  id           String   @id @default(cuid())
  name         String
  type         SourceType
  baseUrl      String?
  feedUrl      String?
  isActive     Boolean  @default(true)
  qualityScore Float?
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  signals      Signal[]
}

model Signal {
  id           String       @id @default(cuid())
  sourceId     String
  title        String
  url          String       @unique
  author       String?
  language     String?
  publishedAt  DateTime?
  ingestedAt   DateTime     @default(now())
  rawContent   String?
  summary      String?
  status       SignalStatus @default(NEW)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  source       Source       @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  tags         SignalTag[]
  clusterItems SignalClusterItem[]
  scores       SignalScore[]
  reviews      HumanReview[]
  topicCandidates TopicCandidate[]

  @@index([sourceId, publishedAt])
  @@index([status])
}

model SignalTag {
  id       String  @id @default(cuid())
  signalId String
  tag      String
  tagType  TagType

  signal   Signal  @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@index([signalId])
  @@index([tag])
  @@index([tagType])
}

model SignalCluster {
  id             String              @id @default(cuid())
  clusterTitle   String
  clusterSummary String?
  heatScore      Float?
  status         ClusterStatus       @default(ACTIVE)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  items          SignalClusterItem[]
  scores         SignalScore[]
  reviews        HumanReview[]
  researchCards  ResearchCard[]

  @@index([status])
}

model SignalClusterItem {
  id              String        @id @default(cuid())
  clusterId       String
  signalId        String
  similarityScore Float?

  cluster         SignalCluster @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  signal          Signal        @relation(fields: [signalId], references: [id], onDelete: Cascade)

  @@unique([clusterId, signalId])
  @@index([signalId])
}

model SignalScore {
  id                  String         @id @default(cuid())
  signalId            String?
  clusterId           String?
  importanceScore     Float
  viewpointScore      Float
  primaryObservationCluster ObservationCluster?
  secondaryObservationCluster ObservationCluster?
  consensusStrength   Float?
  companyRoutineScore Float?
  structuralScore     Float?
  impactScore         Float?
  redistributionScore Float?
  durabilityScore     Float?
  confidenceScore     Float?
  priorityRecommendation PriorityRecommendation @default(WATCH)
  reasoningSummary    String
  reasoningDetail     String?
  modelName           String
  createdAt           DateTime       @default(now())

  signal              Signal?        @relation(fields: [signalId], references: [id], onDelete: Cascade)
  cluster             SignalCluster? @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([signalId, createdAt])
  @@index([clusterId, createdAt])
  @@index([priorityRecommendation, createdAt])
  @@index([primaryObservationCluster, createdAt])
}

model HumanReview {
  id                      String               @id @default(cuid())
  signalId                String?
  clusterId               String?
  reviewStatus            ReviewStatus         @default(PENDING)
  adjustedImportanceScore Float?
  adjustedViewpointScore  Float?
  adjustedConsensusStrength Float?
  adjustedCompanyRoutineScore Float?
  adjustedPriorityRecommendation PriorityRecommendation?
  reasoningAcceptance     ReasoningAcceptance?
  reviewNote              String?
  myAngle                 String?
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt

  signal                  Signal?              @relation(fields: [signalId], references: [id], onDelete: Cascade)
  cluster                 SignalCluster?       @relation(fields: [clusterId], references: [id], onDelete: Cascade)

  @@index([signalId, createdAt])
  @@index([clusterId, createdAt])
  @@index([reviewStatus])
}

model ResearchCard {
  id                   String             @id @default(cuid())
  clusterId            String
  title                String
  eventDefinition      String?
  mainstreamNarrative  String?
  ignoredVariables     String?
  historicalAnalogy    String?
  threeMonthProjection String?
  oneYearProjection    String?
  winnersLosers        String?
  positioningJudgment  String?
  status               ResearchCardStatus @default(DRAFT)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  cluster              SignalCluster      @relation(fields: [clusterId], references: [id], onDelete: Cascade)
  drafts               ContentDraft[]

  @@index([clusterId])
  @@index([status])
}

model ContentDraft {
  id             String        @id @default(cuid())
  researchCardId String
  platform       DraftPlatform
  title          String?
  content        String
  toneVersion    String?
  status         DraftStatus   @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  researchCard   ResearchCard  @relation(fields: [researchCardId], references: [id], onDelete: Cascade)
  feedbackItems  ContentFeedback[]

  @@index([researchCardId])
  @@index([platform, status])
  @@unique([researchCardId, platform])
}

model ContentFeedback {
  id             String        @id @default(cuid())
  contentDraftId String
  platform       DraftPlatform
  publishedAt    DateTime?
  views          Int?
  saves          Int?
  shares         Int?
  comments       Int?
  qualityNotes   String?
  createdAt      DateTime      @default(now())

  contentDraft   ContentDraft  @relation(fields: [contentDraftId], references: [id], onDelete: Cascade)

  @@index([contentDraftId])
  @@index([platform, publishedAt])
}
